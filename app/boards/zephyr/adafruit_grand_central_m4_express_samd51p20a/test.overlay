/ {
    opendeck_retained: opendeck-retained {
    };

    porta: porta {
        compatible = "zephyr,gpio-emul";
        rising-edge;
        falling-edge;
        high-level;
        low-level;
        gpio-controller;
        #gpio-cells = <2>;
        status = "okay";
    };

    portb: portb {
        compatible = "zephyr,gpio-emul";
        rising-edge;
        falling-edge;
        high-level;
        low-level;
        gpio-controller;
        #gpio-cells = <2>;
        status = "okay";
    };

    portc: portc {
        compatible = "zephyr,gpio-emul";
        rising-edge;
        falling-edge;
        high-level;
        low-level;
        gpio-controller;
        #gpio-cells = <2>;
        status = "okay";
    };

    portd: portd {
        compatible = "zephyr,gpio-emul";
        rising-edge;
        falling-edge;
        high-level;
        low-level;
        gpio-controller;
        #gpio-cells = <2>;
        status = "okay";
    };

    adc1: adc1 {
        compatible = "zephyr,adc-emul";
        nchannels = <16>;
        #io-channel-cells = <1>;
        status = "okay";
    };

    sercom0: sercom0 {
        compatible = "zephyr,uart-emul";
        current-speed = <115200>;
        status = "okay";
    };

    sercom6: sercom6 {
        compatible = "zephyr,uart-emul";
        current-speed = <115200>;
        status = "okay";
    };

    sercom3: sercom3@500 {
        compatible = "zephyr,i2c-emul-controller";
        #address-cells = <1>;
        #size-cells = <0>;
        #forward-cells = <1>;
        clock-frequency = <100000>;
        reg = <0x500 4>;
        status = "okay";
    };

    test {
        partitions {
            compatible = "fixed-partitions";
            #address-cells = <1>;
            #size-cells = <1>;

            factory_partition: partition@0 {
                reg = <0x0 0x4000>;
            };

            emueeprom_page1_partition: partition@4000 {
                reg = <0x4000 0x4000>;
            };

            emueeprom_page2_partition: partition@8000 {
                reg = <0x8000 0x4000>;
            };
        };
    };
};

&adc0 {
    nchannels = <16>;
    status = "okay";
};

&flash0 {
    partitions {
        boot_partition: partition@0 {
            compatible = "zephyr,mapped-partition";
            label = "boot";
            reg = <0x00000000 0x0000c000>;
        };

        code_partition: partition@c000 {
            compatible = "zephyr,mapped-partition";
            label = "code-partition";
            reg = <0x0000c000 0x00069000>;
        };
    };
};

opendeck_partition_boot: &boot_partition {};

opendeck_partition_app: &code_partition {};
