mainmenu "OpenDeck bootloader"

OPENDECK_STAGED_DFU_NODE := $(dt_nodelabel_path,opendeck_partition_staged_dfu)

config PROJECT_BOOTLOADER_STAGED_UPDATE
    bool
    default y if $(dt_path_enabled,$(OPENDECK_STAGED_DFU_NODE))
    help
      Hidden symbol. If the target has a staged DFU partition, the
      bootloader can apply raw dfu.bin images written there by the
      application.

config PROJECT_BOOTLOADER_SUPPORT_USB_DFU
    bool "USB DFU support"
    select NET_BUF
    select USB_DEVICE_STACK_NEXT
    select ZLIBS_DRIVERS_USB_HW
    select ZLIBS_DRIVERS_USB_20_EXTENSION_DESC
    help
      Enables the bootloader USB DFU transport when selected by the target
      USB configuration.

source "Kconfig.zephyr"
