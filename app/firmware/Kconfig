config PROJECT_TARGET_SUPPORT_USB_MIDI
    bool "USB MIDI support"
    default y if $(dt_path_enabled,$(OPENDECK_TRANSPORTS_NODE)) && \
             $(dt_nodelabel_bool_prop,opendeck_transports,usb)
    select MIDI2_UMP_STREAM_RESPONDER
    select USBD_MIDI2_CLASS
    select ZLIBS_DRIVERS_USB_HW
    select ZLIBS_UTILS_MIDI_TRANSPORT_USB
    select PROJECT_TARGET_SUPPORT_CONFIG_INTERFACE
    select PROJECT_TARGET_SUPPORT_CONFIG_INTERFACE_USB_MIDI
    help
      Enables USB MIDI transport and SysEx configuration over USB.

