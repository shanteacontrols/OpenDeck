             $(dt_node_str_prop_equals,$(OPENDECK_ANALOG_NODE),mode,native)
    help
      Hidden selector for the native analog input backend.

config PROJECT_TARGET_DRIVER_ANALOG_INPUT_MULTIPLEXER
    bool
    default y if $(dt_path_enabled,$(OPENDECK_ANALOG_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_ANALOG_NODE),mode,4067)
    help
      Hidden selector for the shared-selector analog multiplexer backend.

config PROJECT_TARGET_DRIVER_ANALOG_INPUT_MUXONMUX
