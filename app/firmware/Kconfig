OPENDECK_SWITCHES_NODE := $(dt_nodelabel_path,opendeck_switches)
OPENDECK_ANALOG_NODE := $(dt_nodelabel_path,opendeck_analog)
OPENDECK_OUTPUTS_NODE := $(dt_nodelabel_path,opendeck_outputs)
OPENDECK_TOUCHSCREEN_NODE := $(dt_nodelabel_path,opendeck_touchscreen)
OPENDECK_DIN_MIDI_NODE := $(dt_nodelabel_path,opendeck_din_midi)
OPENDECK_TRAFFIC_INDICATORS_NODE := $(dt_nodelabel_path,opendeck_traffic_indicators)
OPENDECK_DISPLAY_NODE := $(dt_nodelabel_path,opendeck_display)
OPENDECK_STAGED_DFU_NODE := $(dt_nodelabel_path,opendeck_partition_staged_dfu)

config PROJECT_TARGET_SWITCHES_DISABLED
    bool
    default y if !$(dt_path_enabled,$(OPENDECK_SWITCHES_NODE))

config PROJECT_TARGET_ANALOG_DISABLED
    bool
    default y if !$(dt_path_enabled,$(OPENDECK_ANALOG_NODE))

config PROJECT_TARGET_OUTPUTS_DISABLED
    bool
    default y if !$(dt_path_enabled,$(OPENDECK_OUTPUTS_NODE))

config PROJECT_TARGET_TOUCHSCREEN_DISABLED
    bool
    default y if !$(dt_path_enabled,$(OPENDECK_TOUCHSCREEN_NODE))

config PROJECT_TARGET_DIN_MIDI_DISABLED
    bool
    default y if !$(dt_path_enabled,$(OPENDECK_DIN_MIDI_NODE))

config PROJECT_TARGET_TRAFFIC_INDICATORS_DISABLED
    bool
    default y if !$(dt_path_enabled,$(OPENDECK_TRAFFIC_INDICATORS_NODE))

config PROJECT_TARGET_DISPLAY_DISABLED
    bool
    default y if !$(dt_path_enabled,$(OPENDECK_DISPLAY_NODE))

config PROJECT_TARGET_SUPPORT_SWITCHES
    bool
    default y if $(dt_path_enabled,$(OPENDECK_SWITCHES_NODE))
    help
      Hidden compatibility symbol indicating switch support is present on
      this target when the chosen OpenDeck switch devicetree node exists.

config PROJECT_TARGET_SUPPORT_DIGITAL_INPUTS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_SWITCHES_NODE))
    help
      Hidden compatibility symbol indicating digital input support is
      present on this target when the chosen OpenDeck switch devicetree
      node exists.

config PROJECT_TARGET_SUPPORT_ENCODERS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_SWITCHES_NODE)) && \
             $(dt_node_has_prop,$(OPENDECK_SWITCHES_NODE),encoders)
    help
      Hidden compatibility symbol indicating encoder support is present on
      this target when the chosen OpenDeck switch devicetree node
      explicitly enables encoders support.

config PROJECT_TARGET_DRIVER_DIGITAL_INPUT_NATIVE
    bool
    default y if $(dt_path_enabled,$(OPENDECK_SWITCHES_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_SWITCHES_NODE),mode,native)
    help
      Hidden selector for the native switch GPIO backend.

config PROJECT_TARGET_DRIVER_DIGITAL_INPUT_SHIFT_REGISTER
    bool
    default y if $(dt_path_enabled,$(OPENDECK_SWITCHES_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_SWITCHES_NODE),mode,shift-register)
    help
      Hidden selector for the shift-register switch backend.

config PROJECT_TARGET_DRIVER_DIGITAL_INPUT_MATRIX_NATIVE_ROWS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_SWITCHES_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_SWITCHES_NODE),mode,matrix) && \
             $(dt_node_str_prop_equals,$(OPENDECK_SWITCHES_NODE),row-mode,native)
    help
      Hidden selector for the matrix backend with native row inputs.

config PROJECT_TARGET_DRIVER_DIGITAL_INPUT_MATRIX_SHIFT_REGISTER_ROWS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_SWITCHES_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_SWITCHES_NODE),mode,matrix) && \
             $(dt_node_str_prop_equals,$(OPENDECK_SWITCHES_NODE),row-mode,shift-register)
    help
      Hidden selector for the matrix backend with shift-register row
      inputs.

config PROJECT_TARGET_SUPPORT_ADC
    bool
    default y if $(dt_path_enabled,$(OPENDECK_ANALOG_NODE))
    help
      Hidden compatibility symbol indicating ADC support is present on
      this target when the chosen OpenDeck analog devicetree node exists.

config PROJECT_TARGET_SUPPORT_TOUCHSCREEN
