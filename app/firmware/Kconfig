OPENDECK_BUTTONS_NODE := $(dt_nodelabel_path,opendeck_buttons)
OPENDECK_ANALOG_NODE := $(dt_nodelabel_path,opendeck_analog)
OPENDECK_LEDS_NODE := $(dt_nodelabel_path,opendeck_leds)
OPENDECK_TOUCHSCREEN_NODE := $(dt_nodelabel_path,opendeck_touchscreen)
OPENDECK_DIN_MIDI_NODE := $(dt_nodelabel_path,opendeck_din_midi)
OPENDECK_MIDI_INDICATORS_NODE := $(dt_nodelabel_path,opendeck_midi_indicators)
OPENDECK_DISPLAY_NODE := $(dt_nodelabel_path,opendeck_display)

config PROJECT_TARGET_BUTTONS_DISABLED
    bool
    default y if !$(dt_path_enabled,$(OPENDECK_BUTTONS_NODE))

config PROJECT_TARGET_ANALOG_DISABLED
    bool
    default y if !$(dt_path_enabled,$(OPENDECK_ANALOG_NODE))

config PROJECT_TARGET_LEDS_DISABLED
    bool
    default y if !$(dt_path_enabled,$(OPENDECK_LEDS_NODE))

config PROJECT_TARGET_TOUCHSCREEN_DISABLED
    bool
    default y if !$(dt_path_enabled,$(OPENDECK_TOUCHSCREEN_NODE))

config PROJECT_TARGET_DIN_MIDI_DISABLED
    bool
    default y if !$(dt_path_enabled,$(OPENDECK_DIN_MIDI_NODE))

config PROJECT_TARGET_MIDI_INDICATORS_DISABLED
    bool
    default y if !$(dt_path_enabled,$(OPENDECK_MIDI_INDICATORS_NODE))

config PROJECT_TARGET_DISPLAY_DISABLED
    bool
    default y if !$(dt_path_enabled,$(OPENDECK_DISPLAY_NODE))

config PROJECT_TARGET_SUPPORT_BUTTONS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_BUTTONS_NODE))
    help
      Hidden compatibility symbol indicating button support is present on
      this target when the chosen OpenDeck button devicetree node exists.

config PROJECT_TARGET_SUPPORT_DIGITAL_INPUTS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_BUTTONS_NODE))
    help
      Hidden compatibility symbol indicating digital input support is
      present on this target when the chosen OpenDeck button devicetree
      node exists.

config PROJECT_TARGET_SUPPORT_ENCODERS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_BUTTONS_NODE)) && \
             $(dt_node_has_prop,$(OPENDECK_BUTTONS_NODE),encoders)
    help
      Hidden compatibility symbol indicating encoder support is present on
      this target when the chosen OpenDeck button devicetree node
      explicitly enables encoders support.

config PROJECT_TARGET_DRIVER_DIGITAL_INPUT_NATIVE
    bool
    default y if $(dt_path_enabled,$(OPENDECK_BUTTONS_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_BUTTONS_NODE),mode,native)
    help
      Hidden selector for the native button GPIO backend.

config PROJECT_TARGET_DRIVER_DIGITAL_INPUT_SHIFT_REGISTER
    bool
    default y if $(dt_path_enabled,$(OPENDECK_BUTTONS_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_BUTTONS_NODE),mode,shift-register)
    help
      Hidden selector for the shift-register button backend.

config PROJECT_TARGET_DRIVER_DIGITAL_INPUT_MATRIX_NATIVE_ROWS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_BUTTONS_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_BUTTONS_NODE),mode,matrix) && \
             $(dt_node_str_prop_equals,$(OPENDECK_BUTTONS_NODE),row-mode,native)
    help
      Hidden selector for the matrix backend with native row inputs.

config PROJECT_TARGET_DRIVER_DIGITAL_INPUT_MATRIX_SHIFT_REGISTER_ROWS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_BUTTONS_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_BUTTONS_NODE),mode,matrix) && \
             $(dt_node_str_prop_equals,$(OPENDECK_BUTTONS_NODE),row-mode,shift-register)
    help
      Hidden selector for the matrix backend with shift-register row
      inputs.

config PROJECT_TARGET_SUPPORT_ADC
    bool
    default y if $(dt_path_enabled,$(OPENDECK_ANALOG_NODE))
    help
      Hidden compatibility symbol indicating ADC support is present on
      this target when the chosen OpenDeck analog devicetree node exists.

config PROJECT_TARGET_SUPPORT_TOUCHSCREEN
    bool
    default y if $(dt_path_enabled,$(OPENDECK_TOUCHSCREEN_NODE))
    help
      Hidden compatibility symbol indicating touchscreen support is
      present on this target when the chosen OpenDeck touchscreen
      devicetree node exists.

config PROJECT_TARGET_SUPPORT_LEDS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_LEDS_NODE))
    default y if $(dt_path_enabled,$(OPENDECK_TOUCHSCREEN_NODE))
    help
      Hidden compatibility symbol indicating LED support is present on
      this target when the chosen OpenDeck LED devicetree node exists.

config PROJECT_TARGET_SUPPORT_DIGITAL_OUTPUTS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_LEDS_NODE))
    help
      Hidden compatibility symbol indicating digital output support is
      present on this target when the chosen OpenDeck LED devicetree node
      exists.

config PROJECT_TARGET_DRIVER_DIGITAL_OUTPUT_NATIVE
    bool
    default y if $(dt_path_enabled,$(OPENDECK_LEDS_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_LEDS_NODE),mode,native)
    help
      Hidden selector for the native LED backend.

config PROJECT_TARGET_DRIVER_DIGITAL_OUTPUT_SHIFT_REGISTER
    bool
    default y if $(dt_path_enabled,$(OPENDECK_LEDS_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_LEDS_NODE),mode,shift-register)
    help
      Hidden selector for the shift-register LED backend.

config PROJECT_TARGET_DRIVER_DIGITAL_OUTPUT_MATRIX_NATIVE_ROWS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_LEDS_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_LEDS_NODE),mode,matrix)
    help
      Hidden selector for the matrix LED backend with native rows.

config PROJECT_TARGET_DRIVER_DIGITAL_OUTPUT_MAX7219
    bool
    default y if $(dt_path_enabled,$(OPENDECK_LEDS_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_LEDS_NODE),mode,max7219)
    help
      Hidden selector for the MAX7219 LED backend.

config PROJECT_TARGET_DRIVER_ANALOG_INPUT_NATIVE
    bool
    default y if $(dt_path_enabled,$(OPENDECK_ANALOG_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_ANALOG_NODE),mode,native)
    help
      Hidden selector for the native analog input backend.

config PROJECT_TARGET_DRIVER_ANALOG_INPUT_MULTIPLEXER
    bool
    default y if $(dt_path_enabled,$(OPENDECK_ANALOG_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_ANALOG_NODE),mode,4067)
    help
      Hidden selector for the shared-selector analog multiplexer backend.

config PROJECT_TARGET_DRIVER_ANALOG_INPUT_MUXONMUX
    bool
    default y if $(dt_path_enabled,$(OPENDECK_ANALOG_NODE)) && \
             $(dt_node_str_prop_equals,$(OPENDECK_ANALOG_NODE),mode,muxonmux)
    help
      Hidden selector for the mux-on-mux analog backend.

config PROJECT_TARGET_SUPPORT_I2C
    bool
    default y if $(dt_path_enabled,$(OPENDECK_DISPLAY_NODE))
    help
      Hidden compatibility symbol indicating I2C support is present on
      this target when the chosen OpenDeck display devicetree node exists.

config PROJECT_TARGET_SUPPORT_DISPLAY
    bool
    default y if $(dt_path_enabled,$(OPENDECK_DISPLAY_NODE))
    help
      Hidden compatibility symbol indicating display support is present on
      this target when the chosen OpenDeck display devicetree node exists.

config PROJECT_TARGET_SUPPORT_DIN_MIDI
    bool
    default y if $(dt_path_enabled,$(OPENDECK_DIN_MIDI_NODE))
    help
      Hidden symbol indicating DIN MIDI support is present on this target
      when the chosen OpenDeck DIN MIDI devicetree node exists.

config PROJECT_TARGET_SUPPORT_BLE
    bool
    default y if BT && BT_PERIPHERAL
    help
      Hidden symbol indicating BLE MIDI transport support is present on
      this target when Bluetooth peripheral support is enabled for the
      build.

config PROJECT_TARGET_SUPPORT_MIDI_INDICATORS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_MIDI_INDICATORS_NODE))
    help
      Hidden symbol indicating MIDI traffic indicator support is present
      on this target when the chosen MIDI indicators devicetree node
      exists.

config PROJECT_TARGET_SUPPORT_USB_INDICATORS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_MIDI_INDICATORS_NODE)) && \
             $(dt_node_has_prop,$(OPENDECK_MIDI_INDICATORS_NODE),usb_in_gpios) && \
             $(dt_node_has_prop,$(OPENDECK_MIDI_INDICATORS_NODE),usb_out_gpios)
    help
      Hidden symbol indicating USB MIDI traffic indicators are present.

config PROJECT_TARGET_SUPPORT_DIN_INDICATORS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_MIDI_INDICATORS_NODE)) && \
             $(dt_node_has_prop,$(OPENDECK_MIDI_INDICATORS_NODE),din_in_gpios) && \
             $(dt_node_has_prop,$(OPENDECK_MIDI_INDICATORS_NODE),din_out_gpios)
    help
      Hidden symbol indicating DIN MIDI traffic indicators are present.

config PROJECT_TARGET_SUPPORT_BLE_INDICATORS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_MIDI_INDICATORS_NODE)) && \
             $(dt_node_has_prop,$(OPENDECK_MIDI_INDICATORS_NODE),ble_in_gpios) && \
             $(dt_node_has_prop,$(OPENDECK_MIDI_INDICATORS_NODE),ble_out_gpios)
    help
      Hidden symbol indicating BLE MIDI traffic indicators are present.

