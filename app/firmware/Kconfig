config PROJECT_TARGET_SUPPORT_NETWORK
    bool
    default y if $(dt_path_enabled,$(OPENDECK_TRANSPORTS_NODE)) && \
             $(dt_nodelabel_bool_prop,opendeck_transports,network)
    select FPU if CPU_HAS_FPU
    select FPU_SHARING if CPU_HAS_FPU
    select NETWORKING
    select NET_L2_ETHERNET
    select NET_IPV4
    select NET_ARP
    select NET_UDP
    select NET_DHCPV4
    select NET_DHCPV4_OPTION_CALLBACKS
    select NET_SOCKETS
    select NET_CONFIG_SETTINGS
    select NET_CONFIG_NEED_IPV4
    help
      Hidden symbol indicating IP network support is present on this target when
      Ethernet networking is enabled.

config PROJECT_TARGET_SUPPORT_OSC
    bool
    default y if PROJECT_TARGET_SUPPORT_NETWORK
    depends on PROJECT_TARGET_SUPPORT_NETWORK
    help
      Hidden symbol indicating OSC support is present on this target.

config PROJECT_TARGET_SUPPORT_WEBSOCKETS
    bool
    default y if PROJECT_TARGET_SUPPORT_NETWORK
    depends on PROJECT_TARGET_SUPPORT_NETWORK
    select NET_TCP
    select HTTP_SERVER
    select HTTP_SERVER_WEBSOCKET
    select PROJECT_TARGET_SUPPORT_CONFIG_INTERFACE
    select PROJECT_TARGET_SUPPORT_CONFIG_INTERFACE_WEBSOCKETS
    help
      Hidden symbol indicating WebSocket configuration support is present
      on this target.

config PROJECT_TARGET_SUPPORT_MDNS
    bool
    default y if PROJECT_TARGET_SUPPORT_WEBSOCKETS
    depends on PROJECT_TARGET_SUPPORT_NETWORK
    select DNS_SD
    select HWINFO
    select MDNS_RESPONDER
    select MDNS_RESPONDER_DNS_SD
    select NET_HOSTNAME_DYNAMIC
    select NET_HOSTNAME_ENABLE
    help
      Hidden symbol indicating mDNS and DNS-SD discovery support is present
      on this target.

