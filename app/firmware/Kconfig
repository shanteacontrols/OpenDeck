      this target when Bluetooth peripheral support is enabled for the
      build.

config PROJECT_TARGET_SUPPORT_TRAFFIC_INDICATORS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_TRAFFIC_INDICATORS_NODE))
    help
      Hidden symbol indicating traffic indicator support is present
      on this target when the chosen traffic indicators devicetree node
      exists.

config PROJECT_TARGET_SUPPORT_USB_INDICATORS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_TRAFFIC_INDICATORS_NODE)) && \
             $(dt_node_has_prop,$(OPENDECK_TRAFFIC_INDICATORS_NODE),usb_in_gpios) && \
             $(dt_node_has_prop,$(OPENDECK_TRAFFIC_INDICATORS_NODE),usb_out_gpios)
    help
      Hidden symbol indicating USB traffic indicators are present.

config PROJECT_TARGET_SUPPORT_DIN_INDICATORS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_TRAFFIC_INDICATORS_NODE)) && \
             $(dt_node_has_prop,$(OPENDECK_TRAFFIC_INDICATORS_NODE),din_in_gpios) && \
             $(dt_node_has_prop,$(OPENDECK_TRAFFIC_INDICATORS_NODE),din_out_gpios)
