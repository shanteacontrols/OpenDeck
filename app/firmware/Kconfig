config PROJECT_TARGET_SUPPORT_NETWORK_INDICATORS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_TRAFFIC_INDICATORS_NODE)) && \
             $(dt_node_has_prop,$(OPENDECK_TRAFFIC_INDICATORS_NODE),network_in_gpios) && \
             $(dt_node_has_prop,$(OPENDECK_TRAFFIC_INDICATORS_NODE),network_out_gpios)
    help
      Hidden symbol indicating network traffic indicators are present.

config PROJECT_TARGET_SUPPORT_NETWORK_UP_INDICATOR
    bool
    default y if $(dt_path_enabled,$(OPENDECK_TRAFFIC_INDICATORS_NODE)) && \
             $(dt_node_has_prop,$(OPENDECK_TRAFFIC_INDICATORS_NODE),network_up_gpios)
    help
      Hidden symbol indicating a network status indicator is present.

config PROJECT_TARGET_SUPPORT_NETWORK
    bool
    default y if NETWORKING && NET_L2_ETHERNET
    select FPU if CPU_HAS_FPU
    select FPU_SHARING if CPU_HAS_FPU
    select NET_IPV4
    select NET_ARP
    select NET_UDP
    select NET_DHCPV4
    select NET_DHCPV4_OPTION_CALLBACKS
    select NET_SOCKETS
    select NET_CONFIG_SETTINGS
    select NET_CONFIG_NEED_IPV4
    help
      Hidden symbol indicating IP network support is present on this target when
      Ethernet networking is enabled.

config PROJECT_TARGET_SUPPORT_OSC
    bool
    default y if PROJECT_TARGET_SUPPORT_NETWORK
    depends on PROJECT_TARGET_SUPPORT_NETWORK
    help
      Hidden symbol indicating OSC support is present on this target.

config PROJECT_TARGET_SUPPORT_WEBCONFIG
    bool
    default y if PROJECT_TARGET_SUPPORT_NETWORK
    depends on PROJECT_TARGET_SUPPORT_NETWORK
    select NET_TCP
    select HTTP_SERVER
    select HTTP_SERVER_WEBSOCKET
    help
      Hidden symbol indicating WebSocket configuration support is present
      on this target.

config PROJECT_TARGET_SUPPORT_MDNS
    bool
    default y if PROJECT_TARGET_SUPPORT_WEBCONFIG
    depends on PROJECT_TARGET_SUPPORT_NETWORK
    select DNS_SD
    select HWINFO
    select MDNS_RESPONDER
    select MDNS_RESPONDER_DNS_SD
    select NET_HOSTNAME_DYNAMIC
    select NET_HOSTNAME_ENABLE
    help
      Hidden symbol indicating mDNS and DNS-SD discovery support is present
      on this target.

config PROJECT_TARGET_SUPPORT_STAGED_UPDATE
    bool
    default y if $(dt_path_enabled,$(OPENDECK_STAGED_DFU_NODE))
    help
      Hidden symbol indicating staged DFU storage is present on this target.

rsource "src/Kconfig"
