config PROJECT_TARGET_SUPPORT_OUTPUTS
    bool
    default y if $(dt_path_enabled,$(OPENDECK_OUTPUTS_NODE))
    default y if $(dt_path_enabled,$(OPENDECK_TOUCHSCREEN_NODE))
    help
      Hidden compatibility symbol indicating OUTPUT support is present on
      this target when the chosen OpenDeck OUTPUT devicetree node exists.

