menu "MIDI protocol"

config PROJECT_PROTOCOL_MIDI_USB_TX_QUEUE_SIZE
    int
    default USBD_MIDI2_TX_QUEUE_SIZE if USB_DEVICE_STACK_NEXT && USBD_MIDI2_CLASS
    default 256
    help
      Protocol-side USB MIDI TX burst limit. The MIDI handler uses this to
      keep USB bursts below the driver queue capacity, and tests can use it
      without enabling the hardware USB MIDI class.

endmenu
