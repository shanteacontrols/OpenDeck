+    def get_chosen_code_partition_address(self):
+        edt_path = os.path.join(self.cfg.build_dir, 'zephyr', 'edt.pickle.cmake')
+
+        try:
+            with open(edt_path, encoding='utf-8') as edt_file:
+                edt_text = edt_file.read()
+        except OSError:
+            return None
+
+        chosen_match = re.search(r'DT_CHOSEN\|zephyr,code-partition" "([^"]+)"',
+                                 edt_text)
+        if chosen_match is None:
+            return None
+
+        chosen_path = re.escape(chosen_match.group(1))
+        addr_match = re.search(rf'DT_REG\|{chosen_path}\|ADDR" "([^"]+)"',
+                               edt_text)
+        if addr_match is None:
+            return None
+
+        return addr_match.group(1)
+
+    def get_app_address(self):
+        return self.get_chosen_code_partition_address() or self.app_address
+
     def do_run(self, command, **kwargs):
 
         cmd_flash = ['esptool']
