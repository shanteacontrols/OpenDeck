 '''Runner for flashing ESP32 devices with esptool.'''
 
 import os
+import re
 
 from runners.core import RunnerCaps, ZephyrBinaryRunner
 
@@ -82,6 +83,31 @@
             espidf=args.esp_idf_path, encrypt=args.esp_encrypt, no_stub=args.esp_no_stub,
