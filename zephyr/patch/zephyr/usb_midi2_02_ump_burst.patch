+static int usbd_midi_queue_tx_locked(struct usbd_midi_data *data,
+				      const struct midi_ump *umps,
+				      size_t count,
+				      bool *schedule_tx)
+{
+	size_t buflen = 0U;
+	uint32_t word;
+
+	for (size_t packet_index = 0; packet_index < count; packet_index++) {
+		buflen += 4U * UMP_NUM_WORDS(umps[packet_index]);
+	}
+
+	if (buflen > ring_buf_space_get(&data->tx_queue)) {
+		LOG_WRN("Not enough space in tx queue for %u-byte burst", (unsigned int)buflen);
+		return -ENOBUFS;
+	}
+
+	*schedule_tx = ring_buf_size_get(&data->tx_queue) == 0U;
+
+	for (size_t packet_index = 0; packet_index < count; packet_index++) {
+		const struct midi_ump *ump = &umps[packet_index];
+		size_t words = UMP_NUM_WORDS(*ump);
+
+		for (size_t word_index = 0; word_index < words; word_index++) {
+			word = sys_cpu_to_le32(ump->data[word_index]);
+			ring_buf_put(&data->tx_queue, (const uint8_t *)&word, sizeof(word));
+		}
+	}
+
+	return 0;
+}
