+def dt_node_prop_len(kconf, _, path, prop):
+    """
+    This function takes a 'path' and property name ('prop') and returns the
+    number of entries in the devicetree property. Missing nodes and missing
+    properties return 0. Scalar properties return 1.
+    """
+    if doc_mode or edt is None:
+        return "0"
+
+    try:
+        node = edt.get_node(path)
+    except edtlib.EDTError:
+        return "0"
+
+    return str(_node_prop_len(node, prop))
+
+def dt_nodelabel_prop_len(kconf, _, label, prop):
+    """
+    This function takes a node label and property name ('prop') and returns
+    the number of entries in the devicetree property. Missing nodes and
+    missing properties return 0. Scalar properties return 1.
+    """
+    if doc_mode or edt is None:
+        return "0"
+
+    try:
+        node = edt.label2node.get(label)
+    except edtlib.EDTError:
+        return "0"
+
+    if node is None:
+        return "0"
+
+    return str(_node_prop_len(node, prop))
